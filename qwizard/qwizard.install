/**
 *  Post update - remove qw_archive entity def files after update 91001.
 *
 * @param $sandbox
 *
 * @return void
 */
function qwizard_post_update_remove_old_qwsr_archive_class_files(&$sandbox) {
  $file_system = \Drupal::service('file_system');
  $file_system->delete('web/modules/custom/qwizard/src/QwSRArchiveHtmlRouteProvider.php');
  $file_system->delete('web/modules/custom/qwizard/src/Entity/QwSRArchiveInterface.php');
  $file_system->delete('web/modules/custom/qwizard/src/Entity/QwSRArchive.php');
  $file_system->delete('web/modules/custom/qwizard/src/QwSRArchiveAccessControlHandler.php');
}
function _change_field_length(string $field, string $entity_type, int $length){
  $database = \Drupal::database();
  // Retrieve existing field data.
  $tables = [
    "{$entity_type}__$field",
    "{$entity_type}_revision__$field",
  ];
  $existing_data = [];
  foreach ($tables as $table) {
    // Get the old data.
    $existing_data[$table] = $database->select($table)
      ->fields($table)
      ->execute()
      ->fetchAll(PDO::FETCH_ASSOC);

    // Wipe it.
    $database->truncate($table)->execute();
  }

  $field_storage_configs = \Drupal::entityTypeManager()
    ->getStorage('field_storage_config')
    ->loadByProperties([
      'field_name' => $field,
    ]);
  foreach ($field_storage_configs as $field_storage) {
    $new_field_storage = $field_storage->toArray();
    $new_field_storage['settings']['max_length'] = $length;

    $new_field_storage = FieldStorageConfig::create($new_field_storage);
    $new_field_storage->original = $new_field_storage;
    $new_field_storage->enforceIsNew(FALSE);

    $new_field_storage->save();
  }

  // Restore the data.
  foreach ($tables as $table) {
    $insert_query = $database
      ->insert($table)
      ->fields(array_keys(end($existing_data[$table])));
    foreach ($existing_data[$table] as $row) {
      $insert_query->values(array_values($row));
    }
    $insert_query->execute();
  }
}

/**
 * Remove stale qwsr_archive entity due to unnecessary files.
 */
function qwizard_update_91002(&$sandbox) {
  $entity_types = \Drupal::entityTypeManager()->getDefinitions();
  if (!empty($entity_types['qwsr_archive'])) {
    $type = $entity_types['qwsr_archive'];
    $entity_update_manager = \Drupal::entityDefinitionUpdateManager();
    $entity_update_manager->uninstallEntityType($type);
  }
  // Clear all caches, just in case.
  drupal_flush_all_caches();
}

/**
 * Adds field_image to classes vocabulary.
 */
function qwizard_update_91003(&$sandbox) {
  $field_name = 'field_image';
  $entity_type = 'taxonomy_term';
  $bundle = 'classes';

  // Check if field storage already exists.
  if (!\Drupal::service('entity_type.manager')->getStorage('field_storage_config')->load($entity_type . '.' . $field_name)) {
    // Define a field storage.
    $field_storage_config = [
      'field_name' => $field_name,
      'entity_type' => $entity_type,
      'type' => 'image',
      'settings' => [
        'uri_scheme' => 'public',
        'target_type' => 'file',
        'display_field' => FALSE,
        'display_default' => FALSE,
        'default_image' => [
          'uuid' => '',
          'alt' => '',
          'title' => '',
          'width' => NULL,
          'height' => NULL,
        ],
      ],
      'cardinality' => 1,
      'translatable' => TRUE,
      'persist_with_no_fields' => FALSE,
      'custom_storage' => FALSE,
    ];

    $field_storage = FieldStorageConfig::create($field_storage_config);
    $field_storage->enforceIsNew(TRUE);
    $field_storage->save();
  }

  // Check if field already exists on taxonomy term bundle.
  if (!\Drupal::service('entity_type.manager')->getStorage('field_config')->load($entity_type . '.' . $bundle . '.' . $field_name)) {
    // Define a field instance (attaching the field to a specific bundle).
    $field_config = [
      'field_name' => $field_name,
      'entity_type' => $entity_type,
      'bundle' => $bundle,
      'label' => 'Image',
      'description' => '',
      'required' => FALSE,
      'translatable' => FALSE,
      'settings' => [
        'alt_field' => FALSE,
        'alt_field_required' => FALSE,
        'title_field' => FALSE,
        'title_field_required' => FALSE,
      ],
    ];
    $field = FieldConfig::create($field_config);
    $field->enforceIsNew(TRUE);
    $field->save();
  }

  // Update the form display settings.
  $form_display = \Drupal::service('entity_display.repository')->getFormDisplay($entity_type, $bundle);
  $form_display->setComponent($field_name, [
    'type' => 'image_image',
    'weight' => 5,
    'region' => 'content',
    'settings' => [
      'progress_indicator' => 'throbber',
      'preview_image_style' => 'thumbnail',
    ],
  ])->save();

  // Update the view display settings.
  $view_display = \Drupal::service('entity_display.repository')->getViewDisplay($entity_type, $bundle);
  $view_display->setComponent($field_name, [
    'type' => 'image',
    'label' => 'hidden',
    'settings' => [
      'image_link' => '',
      'image_style' => '',
      'image_loading' => [
        'attribute' => 'lazy',
      ],
    ],
    'third_party_settings' => [],
    'weight' => 5,
    'region' => 'content',
    ])->save();
}
