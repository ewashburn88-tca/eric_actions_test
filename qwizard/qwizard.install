<?php
use Drupal\Core\Database\Database;
use Drupal\field\Entity\FieldConfig;
use Drupal\field\Entity\FieldStorageConfig;
use Drupal\Core\Entity\EntityTypeInterface;
use Drupal\Core\Field\BaseFieldDefinition;
use Drupal\user\Entity\User;

/**
 * @file
 * Contains qwizard.install.
 *
 * Install and update function for the qwizard module.
 */

/**
 * Implements hook_install().
 */
function qwizard_install() {
  $voc = ['classes' => 'Classes', 'courses' => 'Courses'];
  $vocabularies = \Drupal\taxonomy\Entity\Vocabulary::loadMultiple();
  foreach ($voc as $vid => $name) {
    if (!isset($vocabularies[$vid])) {
      $vocabulary = \Drupal\taxonomy\Entity\Vocabulary::create([
        'vid'         => $vid,
        'description' => '',
        'name'        => $name,
      ]);
      $vocabulary->save();
    }
  }
}

/**
 * Update 8001 - Changes subscription name length in DB config
 * https://evolvingweb.ca/blog/resizing-fields-drupal-8-without-losing-data
 * http://borutpiletic.com/article/drupal-update-change-field-length
 */
function qwizard_update_8001() {
  $storage_key = 'subscription.field_schema_data.name';
  $storage_schema = \Drupal::keyValue('entity.storage_schema.sql');
  $field_schema = $storage_schema->get($storage_key);
  $field_schema['subscription']['fields']['name']['length'] = 255;
  $field_schema['subscription_revision']['fields']['name']['length'] = 255;
  $storage_schema->set($storage_key, $field_schema);

  $definition = BaseFieldDefinition::create('string')
        ->setLabel(t('Name'))
        ->setDescription(t('The name of the Subscription entity.'))
        ->setRevisionable(TRUE)
        ->setSettings([
          'max_length'      => 255,
          'text_processing' => 0,
        ])
        ->setDefaultValue('')
        ->setDisplayOptions('view', [
          'label'  => 'above',
          'type'   => 'string',
          'weight' => -4,
        ])
        ->setDisplayOptions('form', [
          'type'   => 'string_textfield',
          'weight' => -4,
        ])
        ->setDisplayConfigurable('form', TRUE)
        ->setDisplayConfigurable('view', TRUE)
        ->setRequired(TRUE);

  \Drupal::entityDefinitionUpdateManager()->installFieldStorageDefinition('name', 'subscription', 'subscription_type', $definition);
}

/**
 * Update 8002 - Changes qwiz_result subscription_id settings to avoid LIKE queries
 */
function qwizard_update_8002() {

  $definition = BaseFieldDefinition::create('entity_reference')
    ->setLabel(t('Course'))
    ->setDescription(t('The course of the Question Pool entity.'))
    ->setCardinality(1)
    ->setSetting('target_type', 'taxonomy_term')
    ->setSetting('handler', 'default:taxonomy_term')
    ->setSetting('handler_settings',
      [
        'target_bundles' => [
          'courses' => 'courses',
        ],
      ])
    ->setDisplayOptions('view', [
      'label'  => 'hidden',
      'type'   => 'author',
      'weight' => 0,
    ])
    ->setDisplayOptions('form', [
      'type'     => 'entity_reference_autocomplete',
      'weight'   => 3,
      'settings' => [
        'match_operator'    => 'CONTAINS',
        'size'              => '10',
        'autocomplete_type' => 'tags',
        'placeholder'       => '',
      ],
    ])
    ->setDisplayConfigurable('form', TRUE)
    ->setDisplayConfigurable('view', TRUE);

  \Drupal::entityDefinitionUpdateManager()->installFieldStorageDefinition('subscription_id', 'qwiz_result', null, $definition);
}

/**
 * Update 8003 - Adds subscription.premium column, populates with data. Entup should be ran first
 * Check all subscriptions to see if the user has a premium role or not. Populate the premium column depending on whether it exists or not
 */
function qwizard_update_8003() {
  $prem_courses = [200 => 'navle_premium', 201 => 'bcse_premium'];

  $table_rows = \Drupal::entityQuery('subscription')
    ->notExists('premium')
    ->execute();
  $subscriptions = \Drupal::entityTypeManager()->getStorage('subscription')->loadMultiple($table_rows);

  $users_to_load = [];
  foreach($subscriptions as $subscription) {
    $users_to_load[] = $subscription->getOwnerId();
  }
  $users_loaded = User::loadMultiple($users_to_load);

  foreach($subscriptions as $subscription){
    $user_id = $subscription->getOwnerId();
    $user = $users_loaded[$user_id];
    $course_id = $subscription->getCourseId();
    $is_premium = 0;
    if(!empty($prem_courses[$course_id])){
      if($user->hasRole($prem_courses[$course_id])){
       $is_premium = 1;
      }
    }
    $subscription->set('premium', $is_premium);
    $subscription->save();
  }
}

