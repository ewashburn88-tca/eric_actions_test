/**
 * Update 8006 - uninstall ultimate_cron module and install simple_cron
 */
function qwizard_update_8006() {
  // get module handler
  $module_handler = \Drupal::service('module_handler');
  $module_installer = \Drupal::service('module_installer');

  $ultimate_cron_path = \Drupal::service('extension.list.module')->getPath('ultimate_cron');
  // check if ultimate cron is installed
  if ($module_handler->moduleExists('ultimate_cron')) {
    // uninstall ultimate cron
    $module_installer->uninstall(['ultimate_cron']);
  }

  $simple_cron_path = \Drupal::service('extension.list.module')->getPath('simple_cron');

  // check if this module exists
  if ($simple_cron_path) {
    // check if simple cron is installed
    if (!$module_handler->moduleExists('simple_cron')) {
      // install simple cron
      $module_installer->install(['simple_cron']);

    } else {
      // simple cron is already installed
      \Drupal::logger('qwiz')->notice('Simple cron is already installed');
    }
  } else {
    // log that we need to compose require and install simple cron
    \Drupal::logger('qwiz')->notice('Please run "composer require drupal/simple_cron:^1.0" and then install the simple_cron module');
  }
}

/**
 * Increase FIELD size to 255.
 */
function qwizard_update_8008() {
  _change_field_length('field_card_caption', 'node', 255);
}

/**
 * Increase FIELD size to 255.
 */
function qwizard_update_8010() {
  _change_field_length('field_caption', 'paragraph', 255);
}

/**
 * Update 8012 - install zuku_app module
 */
function qwizard_update_8012() {
  if(!\Drupal::service('module_handler')->moduleExists('zuku_app')){
    \Drupal::service('module_installer')->install(['zuku_app']);
  }
}

