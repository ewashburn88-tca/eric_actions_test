/**
 * Determines if debug mode is on.
 *
 * @return bool
 */
function qwizard_in_debug_mode() {
  $config = \Drupal::config('qwizard.qwizardsettings');
  return !empty($config->get('debug_mode'));
}


/**
 * Taken from
 * https://stackoverflow.com/questions/6329211/php-array-intersect-efficiency
 * Is ~10x faster than built in PHP array intersect
 *
 * @param $arrayOne
 * @param $arrayTwo
 * @return int[]|string[]
 */
function fasterArrayIntersect($arrayOne, $arrayTwo, $arrayThree = []) {
  $index = array_flip($arrayOne);
  $second = array_flip($arrayTwo);

  if(!empty($arrayThree)){
    $third = array_flip($arrayThree);
    $x = array_intersect_key($index, $second, $third);
  }else{
    $x = array_intersect_key($index, $second);
  }


  return array_flip($x);
}

/**
 * Taken from
 * https://stackoverflow.com/questions/2142120/php-encoding-with-domdocument
 * Helps avoid encoding errors down the line when loading a DomDocument
 */
function _qwizard_LoadDomDocument($string){
  $dom_document = new \DOMDocument('1.0', 'UTF-8');
  $dom_document->substituteEntities = TRUE;
  @$dom_document->loadHTML(mb_convert_encoding($string, 'HTML-ENTITIES', 'UTF-8'));
  //@$dom_document->loadHTML($string);

  return $dom_document;
}
