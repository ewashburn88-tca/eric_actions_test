/**
 * Designed to be ran from qwmarked_update_9001 or from /devel/php
 * Will add cron workers for every user to handle defaults on marked questions that are null
 * @param $uid
 * @return void
 */
function _qwmarked_setMarkedQuestionDefaultsForAllUsers($uid = null) {
  // Debug line, used to empty courses entirely
  //$query = \Drupal::database()->update('marked_question_field_data')->fields(['course' => null])->execute();
  \Drupal::service('cache_tags.invalidator')->invalidateTags(['marked_question_list']);

  $queue_service = \Drupal::service('queue');
  $queue = $queue_service->get('setMarkedQuestionCourseWhereNullForUser_QueueWorker');

  if(!empty($uid)){
    $uids = [$uid];
  }else {
    $uids = [];
    $con   = \Drupal\Core\Database\Database::getConnection();
    $query = $con->select('marked_question_field_data', 'mq');
    $query->fields('mq', ['id', 'course', 'uid']);
    $query->isNull('mq.course');
    $marked_questions_with_null_course = $query->execute()->fetchAll(\PDO::FETCH_OBJ);
    foreach($marked_questions_with_null_course as $marked_question){
      if(empty($marked_question->course)){
        $marked_question_uid = $marked_question->uid;
        $uids[$marked_question_uid] = $marked_question_uid;
      }
    }
  }

  foreach($uids as $uid) {
    $queue->createItem(['uid' => $uid]);
  }
}

