<?php

/**
 * @file
 * Provides a marked_question entity type.
 */

use Drupal\Core\Render\Element;
use Drupal\user\Entity\User;

/**
 * Implements hook_theme().
 */
function qwmarked_theme() {
  return [
    'marked_question' => [
      'render element' => 'elements',
    ],
  ];
}

/**
 * Prepares variables for marked_question templates.
 *
 * Default template: marked-question.html.twig.
 *
 * @param array $variables
 *   An associative array containing:
 *   - elements: An associative array containing the marked_question information and any
 *     fields attached to the entity.
 *   - attributes: HTML attributes for the containing element.
 */
function template_preprocess_marked_question(array &$variables) {
  foreach (Element::children($variables['elements']) as $key) {
    $variables['content'][$key] = $variables['elements'][$key];
  }
}


