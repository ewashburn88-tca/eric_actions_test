  <div class="container">
    <h3 class="float-left"><a
        href="{{ url('qwreporting.group_edit', {'group' : group.id}) }}">{{ group.name }}</a>
    </h3>
    <div class="header-links float-right">
      {% if is_admin %}
        <a class="btn btn-secondary"
           href="{{ path('qwmaintenance.qw_maintenance_form', {}, {'query': {'destination': path('<current>'), 'group_id' : group.id }}) }}">
          {{ 'Student Maintenance'|t }}
        </a>
      {% endif %}
      <a class="btn btn-secondary"
         href="{{ url('qwreporting.group_email', {'group_id' : group.id}) }}">{{ 'Email Students' | t }}</a>
    </div>
  </div>
  <div class="clearfix"></div>
  <div>{{ group.description|raw }}</div>
