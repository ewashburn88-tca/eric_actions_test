{% set progressBarClass = is_timed_test_mode ? 'progress-bar-success bg-success' : 'progress-bar-primary bg-primary' %}

<div class="group-individual-results wrapper-class">
  <div class="wrapper">
    {#  <div class="wmd-view-topscroll" >
    <div class="scroll-div1 scroll-div">
    </div>
  </div> #}
    <div class="wrapper wmd-view wmd-view-freeze">
      <div class="scroll-div2 scroll-div results-scroll">

        {# <div class="form-wrapper">

