{#
/**
 * @file qwpool.html.twig
 * Default theme implementation to present Question Pool data.
 *
 * This template is used when viewing Question Pool pages.
 *
 *
 * Available variables:
 * - content: A list of content items. Use 'content' to print all content, or
 * - attributes: HTML attributes for the container element.
 *
 * @see template_preprocess_qwpool()
 *
 * @ingroup themeable
 */
#}
<div{{ attributes.addClass('qwpool') }}>
  {% if content %}
    {{- content -}}
  {% endif %}
</div>
